/* ─── Shared sharp analysis logic ─── */

const SOFT_KEYS = [
  'draftkings','fanduel','betmgm','betrivers',
  'caesars','pointsbetus','williamhill_us','unibet_us'
];

function toImplied(american) {
  return american >= 0
    ? 100 / (100 + american)
    : Math.abs(american) / (Math.abs(american) + 100);
}

function toAmerican(prob) {
  if (prob <= 0 || prob >= 1) return 0;
  if (prob >= 0.5) return -Math.round(prob / (1 - prob) * 100);
  return Math.round((1 - prob) / prob * 100);
}

function fmt(american) {
  return american > 0 ? `+${american}` : String(american);
}

function devig2(p1, p2) {
  const total = p1 + p2;
  return [p1 / total, p2 / total];
}

function analyzeGame(game) {
  const pinBook   = game.bookmakers.find(b => b.key === 'pinnacle');
  const softBooks = game.bookmakers.filter(b => SOFT_KEYS.includes(b.key));
  if (!pinBook || !softBooks.length) return null;

  let bestPlay = null;
  let bestScore = -1;

  for (const mkey of ['h2h', 'spreads', 'totals']) {
    const pinMkt = pinBook.markets.find(m => m.key === mkey);
    if (!pinMkt || pinMkt.outcomes.length < 2) continue;

    const softMkts = softBooks
      .map(sb => sb.markets.find(m => m.key === mkey))
      .filter(Boolean);
    if (!softMkts.length) continue;

    const [pin0Fair, pin1Fair] = devig2(
      toImplied(pinMkt.outcomes[0].price),
      toImplied(pinMkt.outcomes[1].price)
    );
    const pinFair = [pin0Fair, pin1Fair];

    for (let idx = 0; idx < pinMkt.outcomes.length; idx++) {
      const outcome = pinMkt.outcomes[idx];

      const softImps = softMkts.map(sm => {
        const out = sm.outcomes.find(o => o.name === outcome.name);
        return out ? toImplied(out.price) : null;
      }).filter(x => x !== null);
      if (!softImps.length) continue;

      const avgSoftRaw  = softImps.reduce((a, b) => a + b, 0) / softImps.length;
      const avgSoftFair = avgSoftRaw / 1.045; // rough devig
      const gapPP       = (pinFair[idx] - avgSoftFair) * 100;
      if (gapPP <= 0) continue;

      // Signal scores
      const gapScore = Math.min(100, Math.max(0,
        gapPP >= 6   ? 90 + Math.min(10, (gapPP - 6) * 2) :
        gapPP >= 4   ? 72 + (gapPP - 4) * 9 :
        gapPP >= 2.5 ? 52 + (gapPP - 2.5) * 13.3 :
        gapPP >= 1.5 ? 36 + (gapPP - 1.5) * 16 :
        gapPP >= 0.8 ? 18 + (gapPP - 0.8) * 25.7 :
        gapPP * 22.5
      ));

      const softSpread = softImps.length > 1
        ? Math.max(...softImps) - Math.min(...softImps) : 0;
      const divScore = Math.min(100, Math.max(0,
        softSpread >= 0.08 ? 80 + Math.min(20, (softSpread - 0.08) * 250) :
        softSpread >= 0.05 ? 58 + (softSpread - 0.05) * 733 :
        softSpread >= 0.025 ? 32 + (softSpread - 0.025) * 1040 :
        softSpread * 1280
      ));

      const booksOnSide = softImps.filter(p => p < avgSoftRaw + 0.005).length;
      const conScore    = Math.round(booksOnSide / softImps.length * 100);

      const score = Math.round(gapScore * 0.50 + divScore * 0.30 + conScore * 0.20);

      if (score > bestScore) {
        bestScore = score;

        let sideLabel = outcome.name;
        if (mkey === 'spreads' && outcome.point !== undefined)
          sideLabel = `${outcome.name} ${outcome.point > 0 ? '+' : ''}${outcome.point}`;
        else if (mkey === 'totals' && outcome.point !== undefined)
          sideLabel = `${outcome.name} ${outcome.point}`;

        const avgSoftAmerican = toAmerican(avgSoftRaw);
        const softRange = softImps.length > 1
          ? `${fmt(Math.round(toAmerican(Math.min(...softImps))))} – ${fmt(Math.round(toAmerican(Math.max(...softImps))))}`
          : fmt(avgSoftAmerican);

        bestPlay = {
          id:          game.id,
          away:        game.away_team,
          home:        game.home_team,
          commenceTime: game.commence_time,
          sharpSide:   sideLabel,
          market:      mkey,
          score,
          signals: {
            gap:       Math.round(gapScore),
            divergence: Math.round(divScore),
            consensus:  conScore,
          },
          pinnacleLine: fmt(outcome.price),
          softLine:     fmt(avgSoftAmerican),
          softRange,
          gapPP:        gapPP.toFixed(2),
          numBooks:     softImps.length,
        };
      }
    }
  }

  return bestPlay;
}

module.exports = { analyzeGame, SOFT_KEYS };
